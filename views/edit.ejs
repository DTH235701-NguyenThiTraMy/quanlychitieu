<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>Quản lý chi tiêu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div class="container py-4">
        <%- include('navbar') %>

            <div class="card mt-3">
                <div class="card-header fw-bold">
                    ✏️ Sửa giao dịch
                </div>

                <div class="card-body">

                    <form method="POST" enctype="multipart/form-data" action="/transactions/edit/<%= item._id %>">

                        <!-- LOẠI -->
                        <div class="mb-3">
                            <label class="form-label">Loại</label>
                            <select name="type" class="form-select">
                                <option value="thu" <%=item.type==='thu' ? 'selected' : '' %>>Thu</option>
                                <option value="chi" <%=item.type==='chi' ? 'selected' : '' %>>Chi</option>
                            </select>
                        </div>

                        <!-- SỐ TIỀN -->
                        <div class="mb-3">
                            <label class="form-label">Số tiền</label>
                            <input type="number" name="amount" class="form-control" value="<%= item.amount %>" required>
                        </div>

                        <!-- DANH MỤC -->
                        <div class="mb-3">
                            <label class="form-label">Danh mục</label>
                            <select name="category" class="form-select">
                                <% categories.forEach(c=> { %>
                                    <option value="<%= c %>" <%=item.category===c ? 'selected' : '' %>>
                                        <%= c %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>

                        <!-- GHI CHÚ -->
                        <div class="mb-3">
                            <label class="form-label">Ghi chú</label>
                            <input type="text" name="note" class="form-control" value="<%= item.note %>">
                        </div>

                        <!-- NGÀY -->
                        <div class="mb-3">
                            <label class="form-label">Ngày</label>
                            <input type="date" name="date" class="form-control" required
                                value="<%= item.date ? new Date(item.date.getTime() - item.date.getTimezoneOffset()*60000).toISOString().slice(0,10) : '' %>">
                        </div>

                        <!-- ẢNH HIỆN TẠI -->
                        <% if(item.image){ %>
                            <div class="mb-3">
                                <label class="form-label">Ảnh hiện tại</label><br>
                                <img src="<%= item.image %>" width="120" class="rounded shadow-sm">
                            </div>
                            <% } %>

                                <!-- CHỌN ẢNH MỚI -->
                                <div class="mb-3">
                                    <label class="form-label">Chọn ảnh mới</label>
                                    <input type="file" name="image" class="form-control" onchange="previewImage(event)">
                                </div>

                                <!-- PREVIEW -->
                                <div class="mb-3">
                                    <img id="preview" style="width:120px; display:none;" class="rounded shadow-sm">
                                </div>

                                <!-- BUTTON -->
                                <div class="d-flex gap-2">
                                    <button class="btn btn-primary">💾 Lưu</button>
                                    <a href="/transactions" class="btn btn-secondary">⬅ Quay lại</a>
                                </div>

                    </form>

                </div>
            </div>

            <%- include('footer') %>
    </div>

    <script>
        function previewImage(event) {
            const file = event.target.files[0];
            if (!file) return;

            const img = document.getElementById("preview");
            img.src = URL.createObjectURL(file);
            img.style.display = "block";
        }
    </script>

    <%- include('javascript') %>

</body>

</html>
</body>

</html>