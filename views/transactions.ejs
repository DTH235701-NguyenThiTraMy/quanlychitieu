<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>Quản lý chi tiêu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div class="container">
        <%- include('navbar') %>

            <div class="card mt-4">

                <!-- HEADER -->
                <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">

                    <span class="fw-bold">Quản lý chi tiêu</span>

                    <!-- CHỌN THÁNG -->
                    <form method="GET" action="/transactions" class="d-flex gap-2 align-items-center">
                        <input type="month" name="month" value="<%= selectedMonth %>" class="form-control">
                        <button class="btn btn-primary">Xem</button>
                    </form>

                </div>

                <div class="card-body">

                    <!-- THỐNG KÊ + HOẠT ĐỘNG -->
                    <div class="row mb-4 align-items-stretch">

                        <!-- CỘT TRÁI -->
                        <div class="col-md-5">
                            <div class="card h-100">
                                <div class="card-body recent-activity">
                                    <h5 class="mb-2">📅 Hoạt động gần đây</h5>
                                    <!-- <h6 class="text-muted mb-3">5 ngày gần nhất</h6> -->

                                    <% Object.keys(dailyMap) .sort((a, b)=> new Date(b) - new Date(a))
                                        .slice(0,5)
                                        .forEach(date=> { %>

                                        <div class="mb-3 p-2 border rounded">

                                            <div class="d-flex justify-content-between">
                                                <b>
                                                    <%= new Date(date).toLocaleDateString('vi-VN') %>
                                                </b>

                                                <% let balance=dailyMap[date].thu - dailyMap[date].chi; %>

                                                    <% if (balance>= 0) { %>
                                                        <span class="text-success fw-bold">
                                                            +<%= balance.toLocaleString() %> đ
                                                        </span>
                                                        <% } else { %>
                                                            <span class="text-danger fw-bold">
                                                                <%= balance.toLocaleString() %> đ
                                                            </span>
                                                            <% } %>
                                            </div>

                                            <div class="mt-2 d-flex gap-2 flex-wrap">
                                                <% dailyMap[date].images.slice(0,3).forEach(img=> { %>
                                                    <img src="<%= img %>"
                                                        style="width:50px;height:50px;object-fit:cover;border-radius:8px;">
                                                    <% }) %>
                                            </div>

                                        </div>

                                        <% }) %>

                                </div>
                            </div>
                        </div>

                        <!-- CỘT PHẢI -->
                        <div class="col-md-7">
                            <div class="card h-100">
                                <div class="card-body">

                                    <% let [year, month]=selectedMonth.split('-'); %>

                                        <h5 class="mb-3">
                                            📊 Thống kê tháng <%= month %>/<%= year %>
                                        </h5>

                                        <div class="alert alert-success">
                                            💰 Tổng thu:
                                            <b>
                                                <%= (monthThu || 0).toLocaleString() %> VNĐ
                                            </b>
                                        </div>

                                        <div class="alert alert-danger">
                                            💸 Tổng chi:
                                            <b>
                                                <%= (monthChi || 0).toLocaleString() %> VNĐ
                                            </b>
                                        </div>

                                        <div class="alert alert-primary">
                                            📊 Số dư:
                                            <b>
                                                <%= ((monthThu || 0) - (monthChi || 0)).toLocaleString() %> VNĐ
                                            </b>
                                        </div>

                                </div>
                            </div>
                        </div>

                    </div>
                    <hr>

                    <!-- FORM THÊM -->
                    <form method="POST" action="/transactions/add" enctype="multipart/form-data"
                        class="row g-3 mb-4 align-items-end">

                        <div class="col-md-2">
                            <label class="form-label">Loại</label>
                            <select name="type" class="form-select">
                                <option value="thu">Thu</option>
                                <option value="chi">Chi</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Số tiền</label>
                            <input type="number" name="amount" class="form-control" required>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Danh mục</label>
                            <select name="category" class="form-select">
                                <% categories.forEach(c=> { %>
                                    <option value="<%= c %>">
                                        <%= c %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Ngày</label>
                            <input type="date" name="date" class="form-control"
       max="<%= new Date().toISOString().split('T')[0] %>">
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Ảnh</label>
                            <input type="file" name="image" class="form-control">
                        </div>

                        <div class="col-md-2">
                            <button class="btn btn-primary w-100">Thêm</button>
                        </div>

                    </form>


                    <!-- TABLE -->
                    <table class="table table-bordered table-hover align-middle shadow-sm">
                        <thead class="table-dark text-center">
                            <tr>
                                <th>Loại</th>
                                <th>Số tiền</th>
                                <th>Danh mục</th>
                                <th>Ghi chú</th>
                                <th>Ngày</th>
                                <th>Ảnh</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% if (data.length===0) { %>
                                <tr>
                                    <td colspan="7" class="text-center text-muted">
                                        Chưa có dữ liệu
                                    </td>
                                </tr>
                                <% } %>

                                    <% data.forEach(item=> { %>
                                        <tr class="text-center">

                                            <td>
                                                <% if (item.type==='thu' ) { %>
                                                    <span class="badge bg-success px-3">Thu</span>
                                                    <% } else { %>
                                                        <span class="badge bg-danger px-3">Chi</span>
                                                        <% } %>
                                            </td>

                                            <td class="fw-bold text-primary">
                                                <%= item.amount.toLocaleString() %> đ
                                            </td>

                                            <td>
                                                <span class="badge bg-info">
                                                    <%= item.category %>
                                                </span>
                                            </td>

                                            <td>
                                                <%= item.note %>
                                            </td>

                                            <td>
                                                <%= new Date(item.date).toLocaleDateString('vi-VN') %>
                                            </td>

                                            <td>
                                                <% if (item.image) { %>
                                                    <img src="<%= item.image %>"
                                                        style="width:50px;height:50px;object-fit:cover;border-radius:8px;">
                                                    <% } %>
                                            </td>

                                            <td>

                                                <a href="/transactions/edit/<%= item._id %>"
                                                    class="btn btn-warning btn-sm">Sửa</a>

                                                <form action="/transactions/delete/<%= item._id %>" method="POST"
                                                    style="display:inline;">
                                                    <button class="btn btn-danger btn-sm"
                                                        onclick="return confirm('Bạn có chắc muốn xóa?')">
                                                        Xóa
                                                    </button>
                                                </form>

                                            </td>

                                        </tr>
                                        <% }) %>
                        </tbody>
                    </table>

                </div>
            </div>

            <%- include('footer') %>
    </div>

    <%- include('javascript') %>

</body>

</html>