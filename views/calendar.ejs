<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>quản lý chi tiêu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

</head>

<body>
    <!-- NAVBAR -->
    <%- include('navbar') %>

        <div class="container mt-4">

            <h3>📅 Lịch chi tiêu</h3>

            <!-- CHỌN THÁNG -->
            <form method="GET" class="mb-3">
                <input type="month" name="month" value="<%= selectedMonth %>" class="form-control w-25 d-inline">
                <button class="btn btn-primary btn-sm">Xem</button>
            </form>

            <!-- HEADER THỨ -->
            <div class="calendar mb-2">
                <div class="header">CN</div>
                <div class="header">T2</div>
                <div class="header">T3</div>
                <div class="header">T4</div>
                <div class="header">T5</div>
                <div class="header">T6</div>
                <div class="header">T7</div>
            </div>

            <!-- CALENDAR -->
            <div class="calendar">

                <!-- ô trống đầu tháng -->
                <% for(let i=0; i < firstDay; i++) { %>
                    <div></div>
                    <% } %>

                        <!-- ngày -->
                        <% for(let i=1; i <=daysInMonth; i++) { %>
                            <div class="day"
                                onclick="location.href='/transactions?day=<%= i %>&month=<%= selectedMonth %>'">
                                <div class="day-number">
                                    <%= i %>
                                </div>

                                <% if(grouped[i]) { %>
                                    <img src="<%= grouped[i][0].image %>">
                                    <% } %>
                            </div>
                            <% } %>

            </div>

        </div>
        <!-- FOOTER -->
        <%- include('footer') %>
</body>

</html>