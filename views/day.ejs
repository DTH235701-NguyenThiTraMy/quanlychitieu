<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>Quản lý chi tiêu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

    <div class="container py-4">

        <%- include('navbar') %>

            <h3 class="mb-4">
                📅 Ngày: <%= new Date(selectedDate).toLocaleDateString() %>
            </h3>

            <% if(data.length===0){ %>
                <div class="alert alert-info">
                    Không có dữ liệu
                </div>
                <% } %>

                    <div class="row">

                        <% data.forEach(item=> { %>

                            <div class="col-md-4 mb-3">
                                <div class="card">

                                    <% if(item.image){ %>
                                        <img src="<%= item.image %>" class="card-img-top">
                                        <% } %>

                                            <div class="card-body">

                                                <h5>
                                                    <%= item.amount.toLocaleString() %> VNĐ
                                                </h5>

                                                <span class="badge bg-info">
                                                    <%= item.category %>
                                                </span>

                                                <p class="mt-2">
                                                    <%= item.note %>
                                                </p>

                                                <small>
                                                    <%= item.type==='thu' ? '💰 Thu' : '💸 Chi' %>
                                                </small>

                                            </div>

                                </div>
                            </div>

                            <% }) %>

                    </div>

                    <a href="/transactions/calendar" class="btn btn-secondary mt-3">
                        ← Quay lại calendar
                    </a>

                    <%- include('footer') %>

    </div>

</body>

</html>